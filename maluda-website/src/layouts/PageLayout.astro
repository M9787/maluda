---
import BaseLayout from './BaseLayout.astro';
import Navbar from '../components/global/Navbar.astro';
import Footer from '../components/global/Footer.astro';
import { db, Events, Registrations, eq, asc, count } from 'astro:db';

interface Props {
  title: string;
  description?: string;
  heroPoster?: string;
}

const { title, description, heroPoster } = Astro.props;

const activeEvent = await db
  .select()
  .from(Events)
  .where(eq(Events.isActive, true))
  .orderBy(asc(Events.eventDate))
  .get();

let spotsLeft: number | null = null;
let capacity: number | null = null;
if (activeEvent) {
  const [{ value: registeredCount }] = await db
    .select({ value: count() })
    .from(Registrations)
    .where(eq(Registrations.registrationType, 'general'));
  spotsLeft = Math.max(0, activeEvent.capacity - registeredCount);
  capacity = activeEvent.capacity;
}

const eventISO = activeEvent ? new Date(activeEvent.eventDate).toISOString() : null;

const eventJsonLd = activeEvent ? {
  '@context': 'https://schema.org',
  '@type': 'Event',
  name: activeEvent.titleRu,
  startDate: eventISO,
  eventStatus: 'https://schema.org/EventScheduled',
  eventAttendanceMode: 'https://schema.org/OfflineEventAttendanceMode',
  location: {
    '@type': 'Place',
    name: activeEvent.location,
    address: {
      '@type': 'PostalAddress',
      addressLocality: 'Batumi',
      addressCountry: 'GE',
    },
  },
  offers: {
    '@type': 'Offer',
    price: activeEvent.price ?? 0,
    priceCurrency: 'USD',
    availability: 'https://schema.org/InStock',
    url: 'https://maluda.ge/#register',
  },
  organizer: {
    '@type': 'Organization',
    name: 'MaLuDa IT School',
    url: 'https://maluda.ge',
  },
} : null;
---

<BaseLayout title={title} description={description} heroPoster={heroPoster}>
  <Navbar
    activeEvent={activeEvent ? { titleRu: activeEvent.titleRu, location: activeEvent.location, price: activeEvent.price, eventISO } : null}
    spotsLeft={spotsLeft}
    capacity={capacity}
    currentPath={Astro.url.pathname}
  />
  <main id="main" tabindex="-1">
    <slot />
  </main>
  <Footer />
  {eventJsonLd && (
    <script type="application/ld+json" set:html={JSON.stringify(eventJsonLd)} />
  )}
</BaseLayout>

<script>
  // Countdown — targets every element with [data-countdown]. ISO lives on <nav>.
  // Updates once per second when we're inside the last hour (smooth m+s decrement),
  // otherwise once per minute. Interval id is tracked so page unload / view-transition
  // navigation clears it and we don't leak intervals.
  const nav = document.querySelector<HTMLElement>('nav[data-event-iso]');
  const eventISO = nav?.dataset.eventIso;
  if (eventISO) {
    const target = new Date(eventISO).getTime();
    let intervalId: ReturnType<typeof setInterval> | null = null;

    function format(ms: number): string {
      if (ms <= 0) return 'идёт сейчас';
      const totalSec = Math.floor(ms / 1000);
      const days = Math.floor(totalSec / 86_400);
      const hours = Math.floor((totalSec % 86_400) / 3600);
      const minutes = Math.floor((totalSec % 3600) / 60);
      const seconds = totalSec % 60;
      if (days >= 1) return `${days} дн ${hours} ч`;
      if (hours >= 1) return `${hours} ч ${minutes} мин`;
      if (minutes >= 1) return `${minutes} мин ${seconds.toString().padStart(2, '0')} с`;
      return `${seconds} с`;
    }

    function tick() {
      const ms = target - Date.now();
      const text = format(ms);
      document.querySelectorAll<HTMLElement>('[data-countdown]').forEach((el) => {
        el.textContent = text;
      });
      if (ms <= 0 && intervalId !== null) {
        clearInterval(intervalId);
        intervalId = null;
      }
    }

    tick();
    intervalId = setInterval(tick, 1000);
    window.addEventListener('beforeunload', () => {
      if (intervalId !== null) clearInterval(intervalId);
    });
    document.addEventListener('astro:before-swap', () => {
      if (intervalId !== null) clearInterval(intervalId);
    });
  }
</script>
