---
import { t } from '../../i18n';
---

<footer class="border-t border-[var(--color-text-primary)]/8 bg-[var(--color-bg-secondary)] relative overflow-hidden mt-20">
  <!-- Subtle background glow -->
  <div class="absolute top-0 left-1/2 -translate-x-1/2 w-[800px] h-[400px] bg-[var(--color-accent-secondary)] opacity-[0.04] blur-[100px] rounded-full pointer-events-none"></div>

  <!-- Pre-Footer CTA -->
  <div class="border-b border-[var(--color-text-primary)]/8">
    <div class="max-w-6xl mx-auto px-4 py-14 md:py-16 flex flex-col md:flex-row items-center justify-between gap-8 relative z-10">
      <div>
        <h2 class="text-2xl md:text-3xl font-bold mb-2 font-heading text-[var(--color-text-primary)]">
          {t('footer.headline')}
        </h2>
        <p class="text-[var(--color-text-secondary)]">
          {t('footer.text')}
        </p>
      </div>
      <div class="flex flex-col sm:flex-row gap-3 w-full md:w-auto shrink-0">
        <a href="/courses" class="btn-outline w-full sm:w-auto justify-center text-sm py-3 px-6">
          {t('footer.browse')}
        </a>
        <a href="/#register" class="btn-glow w-full sm:w-auto justify-center text-sm py-3 px-6">
          {t('footer.register')}
        </a>
      </div>
    </div>
  </div>

  <!-- Main Footer Content -->
  <div class="max-w-6xl mx-auto px-4 py-14 md:py-16 relative z-10">
    <div class="grid grid-cols-2 md:grid-cols-4 gap-10 md:gap-8">
      
      <!-- Brand Column -->
      <div class="col-span-2 md:col-span-1">
        <a href="/" class="inline-block mb-5">
          <span class="text-xl font-black tracking-tight" style="font-family: 'Manrope', sans-serif;">
            <span class="text-gradient">MALUDA</span>
          </span>
        </a>
        <p class="text-sm text-[var(--color-text-secondary)] leading-relaxed mb-6">
          Практические IT-курсы в Батуми. Живые занятия, малые группы, реальные проекты.
        </p>
        <div class="flex items-center gap-3">
          <a href="https://t.me/maluda_batumi" target="_blank" rel="noopener noreferrer"
            class="w-9 h-9 rounded-full bg-[var(--color-text-primary)]/5 border border-[var(--color-text-primary)]/10 flex items-center justify-center text-[var(--color-text-secondary)] hover:text-[var(--color-accent-secondary)] hover:border-[var(--color-accent-secondary)]/40 hover:bg-[var(--color-accent-secondary)]/5 transition-all duration-200"
            aria-label="Telegram"
          >
            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path d="M12 0C5.373 0 0 5.373 0 12s5.373 12 12 12 12-5.373 12-12S18.627 0 12 0zm5.894 8.221l-1.97 9.28c-.145.658-.537.818-1.084.508l-3-2.21-1.446 1.394c-.14.18-.357.223-.548.223l.188-2.85 5.18-4.686c.223-.198-.054-.31-.346-.11l-6.4 4.02-2.76-.86c-.6-.188-.612-.6.126-.89l10.8-4.16c.5-.188.943.118.804.89z"/>
            </svg>
          </a>
          <a href="https://instagram.com/maluda_batumi" target="_blank" rel="noopener noreferrer"
            class="w-9 h-9 rounded-full bg-[var(--color-text-primary)]/5 border border-[var(--color-text-primary)]/10 flex items-center justify-center text-[var(--color-text-secondary)] hover:text-[var(--color-accent-secondary)] hover:border-[var(--color-accent-secondary)]/40 hover:bg-[var(--color-accent-secondary)]/5 transition-all duration-200"
            aria-label="Instagram"
          >
            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path fill-rule="evenodd" d="M12.315 2c2.43 0 2.784.013 3.808.06 1.064.049 1.791.218 2.427.465a4.902 4.902 0 011.772 1.153 4.902 4.902 0 011.153 1.772c.247.636.416 1.363.465 2.427.048 1.067.06 1.407.06 4.123v.08c0 2.643-.012 2.987-.06 4.043-.049 1.064-.218 1.791-.465 2.427a4.902 4.902 0 01-1.153 1.772 4.902 4.902 0 01-1.772 1.153c-.636.247-1.363.416-2.427.465-1.067.048-1.407.06-4.123.06h-.08c-2.643 0-2.987-.012-4.043-.06-1.064-.049-1.791-.218-2.427-.465a4.902 4.902 0 01-1.772-1.153 4.902 4.902 0 01-1.153-1.772c-.247-.636-.416-1.363-.465-2.427-.047-1.024-.06-1.379-.06-3.808v-.63c0-2.43.013-2.784.06-3.808.049-1.064.218-1.791.465-2.427a4.902 4.902 0 011.153-1.772A4.902 4.902 0 015.45 2.525c.636-.247 1.363-.416 2.427-.465C8.901 2.013 9.256 2 11.685 2h.63zm-.081 1.802h-.468c-2.456 0-2.784.011-3.807.058-.975.045-1.504.207-1.857.344-.467.182-.8.398-1.15.748-.35.35-.566.683-.748 1.15-.137.353-.3.882-.344 1.857-.047 1.023-.058 1.351-.058 3.807v.468c0 2.456.011 2.784.058 3.807.045.975.207 1.504.344 1.857.182.466.399.8.748 1.15.35.35.683.566 1.15.748.353.137.882.3 1.857.344 1.054.048 1.37.058 4.041.058h.08c2.597 0 2.917-.01 3.96-.058.976-.045 1.505-.207 1.858-.344.466-.182.8-.398 1.15-.748.35-.35.566-.683.748-1.15.137-.353.3-.882.344-1.857.048-1.055.058-1.37.058-4.041v-.08c0-2.597-.01-2.917-.058-3.96-.045-.976-.207-1.505-.344-1.858a3.097 3.097 0 00-.748-1.15 3.098 3.098 0 00-1.15-.748c-.353-.137-.882-.3-1.857-.344-1.023-.047-1.351-.058-3.807-.058zM12 6.865a5.135 5.135 0 110 10.27 5.135 5.135 0 010-10.27zm0 1.802a3.333 3.333 0 100 6.666 3.333 3.333 0 000-6.666zm5.338-3.205a1.2 1.2 0 110 2.4 1.2 1.2 0 010-2.4z" clip-rule="evenodd" />
            </svg>
          </a>
        </div>
      </div>

      <!-- Navigation -->
      <div>
        <h3 class="text-xs font-bold text-[var(--color-text-primary)] uppercase tracking-widest mb-5">Навигация</h3>
        <ul class="space-y-3">
          <li><a href="/" class="text-sm text-[var(--color-text-secondary)] hover:text-[var(--color-accent-primary)] transition-colors">Главная</a></li>
          <li><a href="/courses" class="text-sm text-[var(--color-text-secondary)] hover:text-[var(--color-accent-primary)] transition-colors">Курсы</a></li>
          <li><a href="/about" class="text-sm text-[var(--color-text-secondary)] hover:text-[var(--color-accent-primary)] transition-colors">О нас</a></li>
          <li><a href="/faq" class="text-sm text-[var(--color-text-secondary)] hover:text-[var(--color-accent-primary)] transition-colors">FAQ</a></li>
        </ul>
      </div>

      <!-- Courses -->
      <div>
        <h3 class="text-xs font-bold text-[var(--color-text-primary)] uppercase tracking-widest mb-5">Программы</h3>
        <ul class="space-y-3">
          <li><a href="/courses#python" class="text-sm text-[var(--color-text-secondary)] hover:text-[var(--color-course-python)] transition-colors">Python + SQL</a></li>
          <li><a href="/courses#data" class="text-sm text-[var(--color-text-secondary)] hover:text-[var(--color-course-data)] transition-colors">Data Analysis</a></li>
          <li><a href="/courses#devops" class="text-sm text-[var(--color-text-secondary)] hover:text-[var(--color-course-devops)] transition-colors">DevOps & Cloud</a></li>
          <li><a href="/courses#vibe" class="text-sm text-[var(--color-text-secondary)] hover:text-[var(--color-course-vibe)] transition-colors">Vibe Coding & AI</a></li>
        </ul>
      </div>

      <!-- Contact -->
      <div>
        <h3 class="text-xs font-bold text-[var(--color-text-primary)] uppercase tracking-widest mb-5">Контакты</h3>
        <ul class="space-y-4">
          <li class="flex items-start gap-2.5">
            <svg class="w-4 h-4 text-[var(--color-accent-secondary)] shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
            </svg>
            <span class="text-sm text-[var(--color-text-secondary)]">Батуми, Грузия<br/><span class="text-xs">Очные занятия</span></span>
          </li>
          <li class="flex items-start gap-2.5">
            <svg class="w-4 h-4 text-[var(--color-accent-secondary)] shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z" />
            </svg>
            <a href="https://t.me/maluda_batumi" target="_blank" rel="noopener noreferrer" class="text-sm text-[var(--color-text-secondary)] hover:text-[var(--color-accent-secondary)] transition-colors">
              Telegram — написать нам
            </a>
          </li>
        </ul>
      </div>

    </div>
  </div>

  <!-- Copyright Bar -->
  <div class="border-t border-[var(--color-text-primary)]/8 py-6 px-4">
    <div class="max-w-6xl mx-auto flex flex-col sm:flex-row items-center justify-between gap-3 text-xs text-[var(--color-text-secondary)]">
      <p>{t('footer.copyright')} &mdash; {new Date().getFullYear()}</p>
      <div class="flex items-center gap-5">
        <a href="/privacy" class="hover:text-[var(--color-accent-primary)] transition-colors">Политика конфиденциальности</a>
      </div>
    </div>
  </div>
</footer>
