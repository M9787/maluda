---
import PageLayout from '../layouts/PageLayout.astro';
import TiltCard from '../islands/TiltCard';
import { t } from '../i18n';
import { db, Courses, eq, asc } from 'astro:db';

const courseRows = await db
  .select()
  .from(Courses)
  .where(eq(Courses.isActive, true))
  .orderBy(asc(Courses.sortOrder));

interface CourseCard {
  id: string;
  title: string;
  desc: string;
  best_for: string;
  price: string;
  priceLabel: string;
  outcomes: string[];
  color: string;
  duration: string;
  hours: string;
}

const formatPrice = (row: typeof courseRows[number]): { price: string; priceLabel: string } => {
  if (row.priceMonthly && row.priceMonthly > 0) {
    return { price: `$${row.priceMonthly}`, priceLabel: row.priceLabel ?? '/мес' };
  }
  return { price: `$${row.priceTotal}`, priceLabel: row.priceLabel ?? 'за курс' };
};

const toCard = (row: typeof courseRows[number]): CourseCard => {
  const { price, priceLabel } = formatPrice(row);
  let outcomes: string[] = [];
  if (row.outcomesJson) {
    try { outcomes = JSON.parse(row.outcomesJson); } catch { outcomes = []; }
  }
  return {
    id: row.slug,
    title: row.titleRu,
    desc: row.descriptionRu,
    best_for: row.bestForRu ?? '',
    price,
    priceLabel,
    outcomes,
    color: row.accentColor,
    duration: row.durationLabel ?? `${row.durationWeeks} нед`,
    hours: row.hoursLabel ?? `${row.totalHours} часов`,
  };
};

const eventCourses: CourseCard[] = courseRows.filter((c) => c.category === 'event').map(toCard);
const fullCourses: CourseCard[] = courseRows.filter((c) => c.category !== 'event').map(toCard);

const howSteps = [
  { title: t('how.step1.title'), desc: t('how.step1.desc'), icon: '01' },
  { title: t('how.step2.title'), desc: t('how.step2.desc'), icon: '02' },
  { title: t('how.step3.title'), desc: t('how.step3.desc'), icon: '03' },
  { title: t('how.step4.title'), desc: t('how.step4.desc'), icon: '04' },
];
---

<PageLayout title={t('nav.courses')} description={t('courses.headline')}>
  <div class="pt-24 pb-12">
    <!-- COURSES SECTION -->
    <section id="courses" class="py-12 md:py-20 px-4 portal-section">
      <div class="max-w-6xl mx-auto">
        <div class="text-center mb-16">
          <h1 class="text-4xl md:text-5xl lg:text-6xl font-bold mb-6 font-heading" data-animate="heading">
            <span class="text-gradient">{t('courses.headline')}</span>
          </h1>
          <p class="text-lg text-[var(--color-text-secondary)] max-w-2xl mx-auto">
            Живые занятия · Малые группы · Реальные проекты
          </p>
        </div>

        {eventCourses.length > 0 && (
          <div class="mb-16">
            <h2 class="text-2xl md:text-3xl font-bold mb-8 font-heading text-[var(--color-accent-primary)]" data-animate="heading">
              {t('courses.category.events')}
            </h2>
            <div class="grid grid-cols-1 md:grid-cols-2 gap-6" data-animate="card-group">
              {eventCourses.map((course) => (
                <TiltCard client:media="(pointer: fine) and (prefers-reduced-motion: no-preference)" className="glass-card relative overflow-hidden" glowColor={course.color}>
                  <div data-animate="card" class="relative z-10 p-6 md:p-8">
                    <div class="absolute inset-0 pointer-events-none z-0 opacity-[0.06] rounded-xl" style={`background: radial-gradient(ellipse at 30% 0%, ${course.color}, transparent 70%);`}></div>
                    <div class="absolute top-0 left-0 right-0 h-1 rounded-t-xl" style={`background: linear-gradient(90deg, ${course.color}, ${course.color}88)`}></div>

                    <div class="flex items-start justify-between mb-4 relative z-10">
                      <div>
                        <h3 class="text-xl font-bold font-heading">{course.title}</h3>
                        <div class="flex items-center gap-3 mt-1 text-sm text-[var(--color-text-secondary)]">
                          <span>{course.duration}</span>
                          <span class="w-1 h-1 rounded-full bg-[var(--color-text-secondary)]"></span>
                          <span>{course.hours}</span>
                        </div>
                      </div>
                      <span class="text-2xl font-bold font-heading" style={`color: ${course.color}`}>
                        {course.price}
                        <span class="text-sm font-normal text-[var(--color-text-secondary)]">{course.priceLabel}</span>
                      </span>
                    </div>
                    <p class="text-[var(--color-text-secondary)] mb-4 relative z-10">{course.desc}</p>
                    <div class="mb-4 relative z-10">
                      <p class="text-sm font-medium text-[var(--color-text-secondary)] mb-2">{t('courses.learn')}</p>
                      <ul class="space-y-1.5">
                        {course.outcomes.map((outcome) => (
                          <li class="flex items-start gap-2 text-sm">
                            <span style={`color: ${course.color}`} class="mt-1">&#x2022;</span>
                            <span class="text-[var(--color-text-primary)]">{outcome}</span>
                          </li>
                        ))}
                      </ul>
                    </div>
                    {course.best_for && (
                      <p class="text-sm text-[var(--color-text-secondary)] italic relative z-10">
                        <span class="font-medium not-italic">{t('courses.best_for')}</span> {course.best_for}
                      </p>
                    )}
                  </div>
                </TiltCard>
              ))}
            </div>
          </div>
        )}

        <div class="mb-16">
          <h2 class="text-2xl md:text-3xl font-bold mb-8 font-heading text-[var(--color-accent-primary)]" data-animate="heading">
            {t('courses.category.full')}
          </h2>
          <div class="grid grid-cols-1 md:grid-cols-2 gap-6" data-animate="card-group">
            {fullCourses.map((course) => (
              <TiltCard client:media="(pointer: fine) and (prefers-reduced-motion: no-preference)" className="glass-card relative overflow-hidden" glowColor={course.color}>
                <div data-animate="card" class="relative z-10 p-6 md:p-8" id={course.id}>
                  <div class="absolute inset-0 pointer-events-none z-0 opacity-[0.06] rounded-xl" style={`background: radial-gradient(ellipse at 30% 0%, ${course.color}, transparent 70%);`}></div>
                  <div class="absolute top-0 left-0 right-0 h-1 rounded-t-xl" style={`background: linear-gradient(90deg, ${course.color}, ${course.color}88)`}></div>

                  <div class="flex items-start justify-between mb-4 relative z-10">
                    <div>
                      <h3 class="text-xl font-bold font-heading">{course.title}</h3>
                      <div class="flex items-center gap-3 mt-1 text-sm text-[var(--color-text-secondary)]">
                        <span>{course.duration}</span>
                        <span class="w-1 h-1 rounded-full bg-[var(--color-text-secondary)]"></span>
                        <span>{course.hours}</span>
                      </div>
                    </div>
                    <span class="text-2xl font-bold font-heading" style={`color: ${course.color}`}>
                      {course.price}
                      <span class="text-sm font-normal text-[var(--color-text-secondary)]">{course.priceLabel}</span>
                    </span>
                  </div>
                  <p class="text-[var(--color-text-secondary)] mb-4 relative z-10">{course.desc}</p>
                  <div class="mb-4 relative z-10">
                    <p class="text-sm font-medium text-[var(--color-text-secondary)] mb-2">{t('courses.learn')}</p>
                    <ul class="space-y-1.5">
                      {course.outcomes.map((outcome) => (
                        <li class="flex items-start gap-2 text-sm">
                          <span style={`color: ${course.color}`} class="mt-1">&#x2022;</span>
                          <span class="text-[var(--color-text-primary)]">{outcome}</span>
                        </li>
                      ))}
                    </ul>
                  </div>
                  {course.best_for && (
                    <p class="text-sm text-[var(--color-text-secondary)] italic relative z-10">
                      <span class="font-medium not-italic">{t('courses.best_for')}</span> {course.best_for}
                    </p>
                  )}
                </div>
              </TiltCard>
            ))}
          </div>
        </div>

        <p class="text-center text-[var(--color-text-secondary)] mt-12">
          {t('courses.not_sure')}{' '}
          <a href="/#register" class="text-[var(--color-accent-secondary)] hover:underline font-medium">{t('courses.not_sure_cta')}</a>{' '}
          {t('courses.or_telegram')}{' '}
          <a href="https://t.me/maluda_batumi" target="_blank" class="text-[var(--color-accent-secondary)] hover:underline font-medium">
            — мы рады помочь.
          </a>
        </p>
      </div>
    </section>

    <div class="section-divider"></div>

    <!-- HOW IT WORKS SECTION -->
    <section id="how" class="py-20 md:py-28 px-4">
      <div class="max-w-4xl mx-auto">
        <h2 class="text-3xl md:text-4xl font-bold text-center mb-16" data-animate="heading">
          {t('how.headline')}
        </h2>

        <div class="relative">
          <div
            class="hidden md:block absolute left-1/2 top-0 bottom-0 w-px bg-gradient-to-b from-[var(--color-accent-primary)]/30 via-[var(--color-accent-secondary)]/30 to-[var(--color-accent-tertiary)]/30"
            data-animate="step-line"
          ></div>

          <div class="space-y-12 md:space-y-16">
            {howSteps.map((step, i) => (
              <div
                class={`flex flex-col md:flex-row items-center gap-6 ${i % 2 === 1 ? 'md:flex-row-reverse' : ''}`}
                data-animate="step"
              >
                <div class={`flex-1 ${i % 2 === 0 ? 'md:text-right' : 'md:text-left'}`}>
                  <h3 class="text-xl font-bold mb-2">{step.title}</h3>
                  <p class="text-[var(--color-text-secondary)]">{step.desc}</p>
                </div>

                <div class="relative z-10 w-14 h-14 rounded-full glass flex items-center justify-center shrink-0 border border-[var(--color-accent-primary)]/30">
                  <span class="text-xl font-bold text-[var(--color-accent-primary)]">{step.icon}</span>
                </div>

                <div class="flex-1 hidden md:block"></div>
              </div>
            ))}
          </div>
        </div>
      </div>
    </section>
  </div>
</PageLayout>
