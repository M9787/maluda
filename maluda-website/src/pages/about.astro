---
import PageLayout from '../layouts/PageLayout.astro';
import { t } from '../i18n';
import { db, TeamMembers, eq, asc } from 'astro:db';

const socialPoints = [
  { title: t('social.point1.title'), desc: t('social.point1.desc') },
  { title: t('social.point2.title'), desc: t('social.point2.desc') },
  { title: t('social.point3.title'), desc: t('social.point3.desc') },
  { title: t('social.point4.title'), desc: t('social.point4.desc') },
];

const teamRows = await db
  .select()
  .from(TeamMembers)
  .where(eq(TeamMembers.isActive, true))
  .orderBy(asc(TeamMembers.sortOrder));

const teamMembers = teamRows.map((row) => {
  const extras = row as Record<string, unknown>;
  return {
    name: row.name,
    role: row.role,
    bio: row.bio,
    accent: row.accentColor,
    photoUrl: typeof extras.photoUrl === 'string' ? extras.photoUrl : null,
    linkedinUrl: typeof extras.linkedinUrl === 'string' ? extras.linkedinUrl : null,
    telegramUrl: typeof extras.telegramUrl === 'string' ? extras.telegramUrl : null,
  };
});
---

<PageLayout title={t('nav.about')} description={t('team.headline')}>
  <div class="pt-24 pb-12">
    <!-- TEAM SECTION -->
    <section id="team" class="py-12 md:py-20 px-4">
      <div class="max-w-5xl mx-auto">
        <h1 class="text-4xl md:text-5xl font-bold text-center mb-6 font-heading" data-animate="heading">
          <span class="text-gradient">{t('team.headline')}</span>
        </h1>
        <p class="text-center text-lg text-[var(--color-text-secondary)] mb-16 max-w-2xl mx-auto leading-relaxed">
          {t('team.intro')}
        </p>
<div class="grid grid-cols-1 md:grid-cols-3 gap-8 max-w-6xl mx-auto" data-animate="card-group">
  {teamMembers.map((member) => (
    <div class="glass-card hover:-translate-y-2 group transition-all duration-300">
      <div class="relative z-10 p-8 text-center" data-animate="card">
        {/* Avatar — real photo if provided, gradient initial-circle otherwise */}
        <div
          class="w-28 h-28 rounded-full mx-auto mb-5 relative shadow-lg overflow-hidden ring-4"
          style={`background-color: ${member.accent}; color: white; --tw-ring-color: ${member.accent}33;`}
        >
          {member.photoUrl ? (
            <img
              src={member.photoUrl}
              alt={`${member.name} — ${member.role}`}
              width="112"
              height="112"
              loading="lazy"
              decoding="async"
              class="w-full h-full object-cover"
            />
          ) : (
            <div class="w-full h-full flex items-center justify-center text-4xl font-black font-heading">
              {member.name[0]}
            </div>
          )}
        </div>
        <h3 class="text-2xl font-bold mb-1 font-heading">{member.name}</h3>
        <p class="text-xs font-bold mb-4 uppercase tracking-widest" style={`color: ${member.accent}`}>{member.role}</p>
        <p class="text-[var(--color-text-secondary)] leading-relaxed text-sm mb-5">{member.bio}</p>
        <div class="flex items-center justify-center gap-2">
          {member.linkedinUrl && (
            <a
              href={member.linkedinUrl}
              target="_blank"
              rel="noopener noreferrer"
              aria-label={`LinkedIn — ${member.name}`}
              class="w-9 h-9 rounded-full bg-[var(--color-text-primary)]/5 border border-[var(--color-text-primary)]/10 flex items-center justify-center text-[var(--color-text-secondary)] hover:text-[var(--color-accent-secondary)] hover:border-[var(--color-accent-secondary)]/40 transition-colors"
            >
              <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.063 2.063 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
              </svg>
            </a>
          )}
          <a
            href={member.telegramUrl ?? 'https://t.me/maluda_batumi'}
            target="_blank"
            rel="noopener noreferrer"
            aria-label={`Связаться — ${member.name}`}
            class="w-9 h-9 rounded-full bg-[var(--color-text-primary)]/5 border border-[var(--color-text-primary)]/10 flex items-center justify-center text-[var(--color-text-secondary)] hover:text-[var(--color-accent-secondary)] hover:border-[var(--color-accent-secondary)]/40 transition-colors"
          >
            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path d="M12 0C5.373 0 0 5.373 0 12s5.373 12 12 12 12-5.373 12-12S18.627 0 12 0zm5.894 8.221l-1.97 9.28c-.145.658-.537.818-1.084.508l-3-2.21-1.446 1.394c-.14.18-.357.223-.548.223l.188-2.85 5.18-4.686c.223-.198-.054-.31-.346-.11l-6.4 4.02-2.76-.86c-.6-.188-.612-.6.126-.89l10.8-4.16c.5-.188.943.118.804.89z"/>
            </svg>
          </a>
        </div>
      </div>
    </div>
  ))}
</div>
        <p class="text-center text-[var(--color-text-secondary)] mt-12 italic text-sm">
          {t('team.small')}
        </p>
      </div>
    </section>

    <div class="section-divider"></div>

    <!-- SOCIAL PROOF SECTION -->
    <section class="py-20 md:py-28 px-4 bg-[var(--color-bg-secondary)] portal-section relative overflow-hidden">
      <!-- Background effect -->
      <div class="absolute inset-0 bg-gradient-to-br from-[var(--color-accent-primary)]/5 to-transparent pointer-events-none"></div>

      <div class="max-w-5xl mx-auto relative z-10">
        <h2 class="text-3xl md:text-4xl font-bold text-center mb-16" data-animate="heading">
          {t('social.headline')}
        </h2>

        <div class="grid grid-cols-1 sm:grid-cols-2 gap-6 mb-16" data-animate="card-group">
          {socialPoints.map((point) => (
            <div class="glass-card">
              <div class="relative z-10 p-8" data-animate="card">
                <h3 class="text-xl font-bold text-[var(--color-accent-primary)] mb-3">{point.title}</h3>
                <p class="text-[var(--color-text-secondary)] leading-relaxed">{point.desc}</p>
              </div>
            </div>
          ))}
        </div>

        <!-- Quote -->
        <blockquote class="glass p-10 max-w-3xl mx-auto text-center rounded-2xl border border-[var(--color-accent-secondary)]/20 shadow-2xl relative">
          <!-- Quote Icon -->
          <div class="absolute -top-6 left-1/2 -translate-x-1/2 w-12 h-12 bg-[var(--color-bg-secondary)] rounded-full flex items-center justify-center border border-white/10 text-[var(--color-accent-secondary)] text-2xl">
            &ldquo;
          </div>
          <p class="text-xl md:text-2xl text-[var(--color-text-primary)] font-medium italic mb-6 leading-relaxed">
            {t('social.quote')}
          </p>
          <cite class="text-[var(--color-text-secondary)] not-italic font-medium flex items-center justify-center gap-3">
            <span class="w-8 h-px bg-[var(--color-accent-secondary)]/50"></span>
            {t('social.quote_author')}
            <span class="w-8 h-px bg-[var(--color-accent-secondary)]/50"></span>
          </cite>
        </blockquote>
      </div>
    </section>
  </div>
</PageLayout>
